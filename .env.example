# =============================================================================
# SceneArc — Example environment variables
# =============================================================================
# Copy this file to `apps/web/.env.local` and fill in real values.
# NEVER commit a file with real keys. The .gitignore already excludes .env*.
#
# Plain-English notes are included for each value. See NONCODER_GUIDE.md.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (login + database + file storage)
# Get these from your Supabase project: Settings → API.
# -----------------------------------------------------------------------------

# Public project URL. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"

# Public "anon" key. Safe to expose to the browser (Row Level Security protects data).
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# SECRET service-role key. SERVER-ONLY. Never expose to the browser.
# Used only by server code for trusted operations.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# -----------------------------------------------------------------------------
# Language model (AI brain for script analysis)
# Mock mode is the default and needs NONE of these. Set them only when you
# want REAL analysis.
# -----------------------------------------------------------------------------

# Which provider to use: "mock" (free, no key) or "anthropic".
# Defaults to "mock" if unset.
LLM_PROVIDER="mock"

# Model name for the real provider. Example for Anthropic: a small, cheap model.
# Configurable so you can change models without code changes.
LLM_MODEL="claude-haiku-4-5-20251001"

# SECRET API key for the real provider. SERVER-ONLY.
# Leave blank while using mock mode.
LLM_API_KEY=""

# Safety switch for development. When "true", the app shows a confirmation /
# notice before making a PAID model call. Set "false" only when you accept costs.
LLM_CONFIRM_PAID_CALLS="true"
